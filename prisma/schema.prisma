generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////
// ENUMS
//////////////////////

enum Role {
  ADMIN
  PROJECT_MANAGER
  MEMBER
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum ActivityAction {
  TASK_CREATED
  TASK_UPDATED
  TASK_DELETED
  TASK_COMPLETED

  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_DELETED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

//////////////////////
// USER
//////////////////////

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String
  role     Role   @default(MEMBER)

  avatar   String?
  bio      String?
  isActive Boolean   @default(true)
  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  managedProjects Project[] @relation("ProjectManager")
  tasks           TaskAssignee[]
  comments        Comment[]
  notifications   Notification[]
  activities      ActivityLog[]
  memberships     ProjectMember[]
}

//////////////////////
// PROJECT
//////////////////////

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?

  deadline    DateTime
  status      ProjectStatus @default(ACTIVE)

  progress    Int @default(0)
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // manager
  managerId String
  manager   User @relation("ProjectManager", fields: [managerId], references: [id], onDelete: Cascade)

  // relations
  tasks        Task[]
  members      ProjectMember[]
  activityLogs ActivityLog[]

  @@index([managerId])
}

//////////////////////
// PROJECT MEMBER
//////////////////////

model ProjectMember {
  id String @id @default(cuid())

  userId    String
  projectId String

  role Role @default(MEMBER)

  joinedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
}

//////////////////////
// TASK
//////////////////////

model Task {
  id String @id @default(cuid())

  title       String
  description String?

  dueDate  DateTime
  priority TaskPriority @default(MEDIUM)
  status   TaskStatus   @default(TODO)

  estimatedHours Int?
  actualHours    Int?

  completedAt DateTime?
  attachmentUrl String?

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assignees TaskAssignee[]

  comments     Comment[]
  attachments  Attachment[]
  activityLogs ActivityLog[]

  @@unique([title, projectId])
  @@index([projectId])
  @@index([status])
  @@index([dueDate])
}

//////////////////////
// TASK ASSIGNEE (FIXED: MULTI USER SUPPORT)
//////////////////////

model TaskAssignee {
  id String @id @default(cuid())

  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

//////////////////////
// COMMENT
//////////////////////

model Comment {
  id      String @id @default(cuid())
  content String

  createdAt DateTime @default(now())

  taskId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

//////////////////////
// ATTACHMENT
//////////////////////

model Attachment {
  id String @id @default(cuid())

  fileName String
  fileUrl  String
  fileType String?
  fileSize Int?
  mimeType String?

  uploadedAt DateTime @default(now())

  taskId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

//////////////////////
// NOTIFICATION
//////////////////////

model Notification {
  id String @id @default(cuid())

  title   String
  message String
  isRead  Boolean @default(false)

  type NotificationType @default(INFO)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

//////////////////////
// ACTIVITY LOG (FINAL PRO FIX)
//////////////////////

model ActivityLog {
  id String @id @default(cuid())

  action  ActivityAction

  details Json?

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  taskId String?
  task   Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([projectId])
  @@index([taskId])
  @@index([createdAt])
}